# Study SparkAI backend environment
# Copy this file to .env. The app runs locally with only MongoDB and, for AI features, Groq.

# App
NODE_ENV=development
PORT=4009 
API_URL=http://localhost:4009
CLIENT_URL=http://localhost:5173

# Database: free options
# - Local MongoDB: mongodb://127.0.0.1:27017/study_sparkai
# - MongoDB Atlas free M0 cluster: https://www.mongodb.com/atlas
MONGODB_URI=mongodb://127.0.0.1:27017/study_sparkai

# JWT secrets: generate each with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-64-byte-random-hex-secret
JWT_REFRESH_SECRET=replace-with-a-different-64-byte-random-hex-secret
JWT_RESET_SECRET=replace-with-another-64-byte-random-hex-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
PASSWORD_RESET_TTL=1h
COOKIE_SECURE=false

# Email verification/password notifications
# Optional locally. If blank, verification codes are returned in dev API responses.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Study SparkAI <no-reply@studysparkai.local>"

# AI: Groq free API keys from https://console.groq.com
# Free model defaults: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=mixtral-8x7b-32768
GROQ_EXPLANATION_MODEL=gemma2-9b-it

# File uploads
# Optional: Cloudinary free tier at https://cloudinary.com. Leave blank to use local uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=study-sparkai/resources

# Redis caching/queues
# Optional: Upstash free Redis at https://upstash.com or local Redis. Leave blank to disable Redis features.
REDIS_URL=

# Zoom meetings
# Optional: create a Zoom Server-to-Server OAuth app at https://marketplace.zoom.us.
# This app type runs fully in the backend. It does not use redirect URLs, allow lists,
# teacher browser login, or /api/meetings/zoom/callback.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Use a Zoom user email/id. If left as "me", the app will try to resolve the first active account user.
# To auto-invite/upgrade teachers as alternative hosts, the Zoom app owner must be an account admin
# and the Server-to-Server OAuth app needs admin user-management scopes such as user:read:admin and user:write:admin.
ZOOM_HOST_USER_ID=me
ZOOM_TIMEZONE=Asia/Karachi
ZOOM_WAITING_ROOM=true
ZOOM_JOIN_BEFORE_HOST=false
ZOOM_MUTE_UPON_ENTRY=true
ZOOM_AUTO_RECORDING=none
